{
    "name": "@lingames/clever-sdk",
    "version": "0.1.28",
    "description": "Clever SDK",
    "main": "./dist/CleverSDK.js",
    "module": "./dist/CleverSDK.mjs",
    "types": "./dist/CleverSDK.d.ts",
    "files": [
        "dist",
        "native",
        "src"
    ],
    "exports": {
        ".": {
            "require": "./dist/CleverSDK.js",
            "import": "./dist/CleverSDK.mjs",
            "types": "./dist/CleverSDK.d.ts",
            "default": "./dist/CleverSDK.js"
        },
        "./models": {
            "types": "./src/models/index.ts"
        }
    },
    "scripts": {
        "clean": "rimraf dist",
        "prepublish": "pnpm run build",
        "build": "pnpm run clean && rollup -c rollup.config.mjs"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "devDependencies": {
        "@rollup/plugin-node-resolve": "^16.0.1",
        "@rollup/plugin-terser": "^0.4.4",
        "@rollup/plugin-typescript": "^12.1.2",
        "axios": "^1.8.4",
        "jssha": "^3.3.1",
        "rimraf": "^6.0.1",
        "rollup": "^4.40.1",
        "rollup-plugin-dts": "^6.2.1",
        "tslib": "^2.8.1",
        "typescript": "^5.8.3"
    }
}

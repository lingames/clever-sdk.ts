{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "module": "NodeNext",
        "moduleResolution": "nodenext",
        "target": "ESNext",
        //        "module": "AMD",
        "allowJs": true,
        "checkJs": false,
        //        "moduleResolution": "node",
        "removeComments": true,
        "lib": ["es5", "es6", "dom"],
        "outDir": "dist",
